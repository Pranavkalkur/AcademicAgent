# ==========================================
# Academic Agent - Production .gitignore
# ==========================================

# 📦 Dependencies & Packages
node_modules/
jspm_packages/
.pnp
.pnp.js

# 🔑 Environment Variables & Secrets
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local
# Gemini API Keys and other credentials should never be committed
*secret*
*credential*

# 🏗️ Build & Production Outputs
dist/
dist-ssr/
build/
out/
.next/
.nuxt/

# 📝 Logs & Temporary Files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
temp/
tmp/
.temp/

# 📁 Uploads & Dynamic Data
uploads/
public/uploads/
images/uploads/

# 📊 MongoDB & Databases
dump/
*.bson
*.json.gz
db_backups/

# 🧪 Testing & Coverage
coverage/
.nyc_output/
.tox/
.jest/

# 💻 OS-Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# 🛠️ IDEs & Editors
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.project
.classpath
.c9/
*.launch
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.vimrc
.fleet/

# ⚡ Cache Directories
.eslintcache
.stylelintcache
.npm
.yarn
.parcel-cache/
.vite/
node_modules/.cache/
